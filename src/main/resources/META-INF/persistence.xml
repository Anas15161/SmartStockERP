<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="SmartStockPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.smartstock.erp.model.Product</class>
        <class>com.smartstock.erp.model.Supplier</class>
        <class>com.smartstock.erp.model.GlobalSetting</class>
        <!-- Nouvelles entités v2.0 -->
        <class>com.smartstock.erp.model.Role</class>
        <class>com.smartstock.erp.model.User</class>
        <class>com.smartstock.erp.model.StockMovement</class>
        <class>com.smartstock.erp.model.PurchaseOrder</class>
        <class>com.smartstock.erp.model.PurchaseOrderItem</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- Oracle Database Configuration -->
            <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.OracleDriver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@127.0.0.1:1521/XEPDB1"/>
            <property name="jakarta.persistence.jdbc.user" value="smartstock"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>

            <!-- Hibernate Settings -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.OracleDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>

            <!-- Performance Tuning -->
            <property name="hibernate.temp.use_jdbc_metadata_defaults" value="false"/>
            <property name="hibernate.jdbc.batch_size" value="30"/>
            <property name="hibernate.order_inserts" value="true"/>
            <property name="hibernate.order_updates" value="true"/>
            <property name="hibernate.connection.provider_disables_autocommit" value="true"/>
        </properties>
    </persistence-unit>
</persistence>